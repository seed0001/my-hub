generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  createdAt    DateTime  @default(now())

  projects      Project[]
  bookmarks     Bookmark[]
  messages      ChatMessage[]
  artifacts     Artifact[]
  reminders     Reminder[]
  focusSessions FocusSession[]
  pushSubs      PushSubscription[]
  memories      Memory[]
  profile       UserProfile?
}

enum ProjectStatus {
  IDEA
  PLANNING
  ACTIVE
  PAUSED
  DONE
  ARCHIVED
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(IDEA)
  url         String?
  repoUrl     String?
  color       String? // optional accent color for the card
  pinned      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  updates       ProjectUpdate[]
  artifacts     Artifact[]
  reminders     Reminder[]
  focusSessions FocusSession[]

  @@index([userId])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([projectId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  url       String
  note      String?  @db.Text
  category  String? // free-form grouping, e.g. "Tools", "Reading"
  tags      String[] @default([])
  favicon   String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// A document the assistant (or the user) creates: roadmaps, specs, notes.
// `num` is a friendly sequential ID surfaced as "A-12" in the catalog.
model Artifact {
  id        String   @id @default(cuid())
  num       Int      @unique @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  kind      String   @default("doc") // roadmap | spec | note | doc
  content   String   @db.Text // markdown
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
}

model Reminder {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?   @db.Text
  dueAt     DateTime
  status    String    @default("PENDING") // PENDING | SENT | DONE | DISMISSED
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())

  @@index([userId, status, dueAt])
}

// One timed work block on a project. Round-robin "next up" is the
// in-motion project whose latest session is oldest (or has none).
model FocusSession {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  minutes   Int
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@index([userId, startedAt])
}

// One durable fact the assistant has learned (preferences, context, etc.).
model Memory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// A living markdown profile of the user, maintained by the assistant:
// who they are, where they live, interests, hobbies, working style.
model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @default("") @db.Text
  updatedAt DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Durable audit trail for every attempted GitHub/Railway integration
// operation. Deliberately not FK-linked to User so audit history survives
// account changes. Never contains tokens, secret values, or unredacted output.
model IntegrationLog {
  id            String   @id @default(cuid())
  userId        String?
  integration   String // "github" | "railway"
  tool          String
  correlationId String
  riskClass     String // READ | WRITE | DESTRUCTIVE
  target        String? // sanitized target identifier, e.g. "owner/repo"
  confirmation  String? // not_required | required | confirmed
  outcome       String // SUCCESS | FAILURE | CANCELLED | BLOCKED
  errorCategory String?
  errorMessage  String?  @db.Text // sanitized
  durationMs    Int
  createdAt     DateTime @default(now())

  @@index([integration, createdAt])
  @@index([userId, createdAt])
}

// Single-use, short-lived confirmation for high-risk integration actions.
// Bound to user + tool + exact normalized argument hash; consumed atomically.
model PendingAction {
  id         String    @id @default(cuid())
  userId     String
  tool       String
  argsHash   String
  argsJson   String    @db.Text // sanitized normalized args (never secret values)
  summary    String    @db.Text
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, expiresAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
