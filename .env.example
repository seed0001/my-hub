# ---- Database (Railway Postgres) ----
# Railway injects this automatically when you attach a Postgres plugin.
# For local dev, point at a local or Railway Postgres instance.
DATABASE_URL="postgresql://user:password@localhost:5432/myhub?schema=public"

# ---- Auth ----
# Long random string used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- OpenRouter (AI assistant) ----
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."
# Any model slug from https://openrouter.ai/models
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# Optional: your public site URL (used for OpenRouter attribution headers)
APP_URL="http://localhost:3000"
