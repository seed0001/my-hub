# ---- Database (Railway Postgres) ----
# Railway injects this automatically when you attach a Postgres plugin.
# For local dev, point at a local or Railway Postgres instance.
DATABASE_URL="postgresql://user:password@localhost:5432/myhub?schema=public"

# ---- Auth ----
# Long random string used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- OpenRouter (AI assistant) ----
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."
# Any model slug from https://openrouter.ai/models
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# Optional: your public site URL (used for OpenRouter attribution headers)
APP_URL="http://localhost:3000"

# ---- GitHub integration (assistant management tools) ----
# Fine-grained PAT with least privilege — only the repos Andrew should manage,
# only the scopes you actually use. Never commit real values.
# GH_TOKEN=""

# ---- Railway integration (assistant management tools) ----
# Account/workspace token for the public GraphQL API (Account Settings → Tokens).
# RAILWAY_API_TOKEN=""
# Optional: Railway CLI auth (only whoami/list use the CLI).
# RAILWAY_TOKEN=""
# Optional: override the public API endpoint.
# RAILWAY_API_URL="https://backboard.railway.com/graphql/v2"

# Optional: absolute path enabling `gh repo create --source` from local
# projects. Leave unset to keep local-path operations disabled (default).
# INTEGRATIONS_WORKSPACE_ROOT=""
